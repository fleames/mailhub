{
  "name": "mailhub",
  "version": "2.0.0",
  "private": true,
  "license": "GPL-3.0-only",
  "description": "Personal multi-domain email hub",
  "scripts": {
    "dev": "next dev -p 3480",
    "build": "next build",
    "start": "next start -p 3480",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env scripts/migrate.mjs",
    "db:seed": "node --env-file-if-exists=.env --import tsx src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@tiptap/extension-link": "^3.0.0",
    "@tiptap/extension-placeholder": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^2.19.0",
    "jose": "^6.0.0",
    "lucide-react": "^0.525.0",
    "mailparser": "^3.7.1",
    "marked": "^16.0.0",
    "next": "^16.0.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^3.0.0",
    "resend": "^6.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.4.11",
      "esbuild": ">=0.25.0",
      "postcss": ">=8.5.10"
    }
  }
}
