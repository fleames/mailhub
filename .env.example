# ------- Required -------
# Login password for the web UI
APP_PASSWORD=change-me
# Session signing secret (>= 32 chars):  openssl rand -hex 32
AUTH_SECRET=change-me-change-me-change-me-change-me
# Shared secret between the Cloudflare Email Worker and /api/inbound (>= 16 chars)
INBOUND_SECRET=change-me-change-me

# Public URL of the app (used in notification links + setup guide)
APP_URL=http://localhost:3480

# Local dev database (Docker compose overrides this inside the network)
DATABASE_URL=postgres://mailhub:mailhub@localhost:5448/mailhub
# POSTGRES_PASSWORD=mailhub

# ------- Outbound email (Resend) — can also be set in Settings → Sending -------
# RESEND_API_KEY=re_...
# RESEND_WEBHOOK_SECRET=whsec_...   (Resend → Webhooks → endpoint: https://<APP_URL>/api/webhooks/resend)

# ------- Cloudflare R2 -------
# Required for INBOUND mail on a local PC: the Email Worker buffers messages into
# this bucket's queue/ prefix and the app pulls them every 60s. Also used for
# attachment/raw storage when set (local disk fallback otherwise).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=mailhub
# STORAGE_DIR=./data/storage

# ------- AI (OpenAI-compatible; DeepSeek default) — can also be set in Settings → AI -------
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# Undo-send window in seconds
# UNDO_SEND_SECONDS=15
